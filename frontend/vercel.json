{
  "headers": [
    {
      "source": "/uploads/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "http://85.239.60.54/api/:path*" },
    { "source": "/uploads/:path*", "destination": "http://85.239.60.54/uploads/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
